generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  ACCOUNTANT
  SALES
  EMPLOYEE
}

enum PlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  CASH
  STRIPE
  OTHER
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  WHATSAPP
}

enum ProductType {
  SERVICE
  DIGITAL
  PHYSICAL
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN
  TRANSFER
  TRANSFER_IN
  IN
}

enum AutomationTrigger {
  INVOICE_CREATED
  INVOICE_PAID
  INVOICE_OVERDUE
  QUOTE_ACCEPTED
  QUOTE_CREATED
  LEAD_CREATED
  DEAL_STAGE_CHANGED
  PAYMENT_RECEIVED
  CLIENT_CREATED
  ORDER_CREATED
  PURCHASE_ORDER_RECEIVED
  LOW_STOCK
}

enum AutomationActionType {
  SEND_EMAIL
  CREATE_NOTIFICATION
  SEND_WEBHOOK
  UPDATE_DEAL_STAGE
}

enum VerifactuStatus {
  GENERATED
  SIGNED
  SENT
  ACCEPTED
  REJECTED
}

enum DeliveryNoteStatus {
  DRAFT
  SENT
  DELIVERED
  INVOICED
  CANCELLED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum ContractType {
  INDEFINIDO
  TEMPORAL
  PRACTICAS
  AUTONOMO
  OBRA_SERVICIO
}

enum LeaveType {
  VACATION
  SICK
  PERSONAL
  MATERNITY
  PATERNITY
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

enum JournalEntryType {
  INVOICE
  PAYMENT
  REFUND
  ADJUSTMENT
  MANUAL
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
  WHATSAPP
}

// ============================================================
// TENANT / COMPANY
// ============================================================

model Company {
  id             String    @id @default(uuid())
  name           String
  legalName      String?
  cif            String?
  vatNumber      String?
  email          String
  phone          String?
  address        String?
  city           String?
  province       String?
  postalCode     String?
  country        String    @default("ES")
  logo           String?
  website        String?
  plan           PlanType  @default(FREE)
  trialEndsAt    DateTime?
  stripeCustomerId String? @unique
  stripeSubId    String?   @unique
  isActive       Boolean   @default(true)
  settings       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  users          UserCompany[]
  clients        Client[]
  leads          Lead[]
  pipelines      Pipeline[]
  invoices       Invoice[]
  quotes         Quote[]
  products       Product[]
  taxes          Tax[]
  bankAccounts   BankAccount[]
  accounts       Account[]
  journalEntries JournalEntry[]
  verifactuRecords VerifactuRecord[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  warehouses     Warehouse[]
  suppliers      Supplier[]
  invoiceSeries  InvoiceSeries[]
  automations    Automation[]
  invitations    Invitation[]
  deliveryNotes  DeliveryNote[]
  employees      Employee[]
  payrolls       Payroll[]
  orders         Order[]
  purchaseOrders PurchaseOrder[]
  projects       Project[]
  customFields   CustomField[]
  expenses       Expense[]
  fiscalPeriods  FiscalPeriod[]

  @@map("companies")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String
  firstName      String
  lastName       String
  avatar         String?
  phone          String?
  isActive       Boolean   @default(true)
  emailVerified  Boolean   @default(false)
  emailVerifyToken String?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  googleId       String?   @unique
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  companies      UserCompany[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]
  activities     Activity[]

  @@map("users")
}

model UserCompany {
  id         String    @id @default(uuid())
  userId     String
  companyId  String
  role       UserRole  @default(EMPLOYEE)
  isDefault  Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("user_companies")
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  userId     String
  expiresAt  DateTime
  revoked    Boolean   @default(false)
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Invitation {
  id          String    @id @default(uuid())
  companyId   String
  email       String
  role        UserRole  @default(EMPLOYEE)
  token       String    @unique @default(uuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([companyId])
  @@map("invitations")
}

// ============================================================
// CRM
// ============================================================

enum ClientType {
  EMPRESA
  AUTONOMO
  PARTICULAR
}

model Client {
  id             String     @id @default(uuid())
  companyId      String
  name           String
  legalName      String?
  cifNif         String?
  clientType     ClientType @default(EMPRESA)
  email          String?
  phone          String?
  mobile         String?
  address        String?
  city           String?
  province       String?
  postalCode     String?
  country        String    @default("ES")
  website        String?
  notes          String?
  avatar         String?
  isActive       Boolean   @default(true)
  totalBilled    Decimal   @default(0) @db.Decimal(12, 2)
  pendingBalance Decimal   @default(0) @db.Decimal(12, 2)
  portalToken    String?   @unique
  tags           ClientTag[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  quotes         Quote[]
  deals          Deal[]
  activities     Activity[]
  contacts       Contact[]
  deliveryNotes  DeliveryNote[]
  orders         Order[]
  projects       Project[]

  @@index([companyId])
  @@map("clients")
}

model Contact {
  id         String    @id @default(uuid())
  clientId   String
  name       String
  email      String?
  phone      String?
  position   String?
  isPrimary  Boolean   @default(false)
  createdAt  DateTime  @default(now())

  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model Tag {
  id        String      @id @default(uuid())
  companyId String
  name      String
  color     String      @default("#6366f1")
  clients   ClientTag[]

  @@unique([companyId, name])
  @@map("tags")
}

model ClientTag {
  clientId  String
  tagId     String

  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@map("client_tags")
}

model Lead {
  id         String    @id @default(uuid())
  companyId  String
  name       String
  email      String?
  phone      String?
  company    String?
  source     String?
  notes      String?
  isConverted Boolean  @default(false)
  clientId   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deals      Deal[]

  @@index([companyId])
  @@map("leads")
}

model Pipeline {
  id        String          @id @default(uuid())
  companyId String
  name      String
  isDefault Boolean         @default(false)
  createdAt DateTime        @default(now())

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stages    PipelineStage[]

  @@map("pipelines")
}

model PipelineStage {
  id         String    @id @default(uuid())
  pipelineId String
  name       String
  order      Int
  color      String    @default("#6366f1")
  deals      Deal[]

  pipeline   Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@map("pipeline_stages")
}

model Deal {
  id         String        @id @default(uuid())
  companyId  String
  clientId   String?
  leadId     String?
  stageId    String
  title      String
  value      Decimal       @default(0) @db.Decimal(12, 2)
  currency   String        @default("EUR")
  stage      DealStage     @default(LEAD)
  closeDate  DateTime?
  notes      String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  client     Client?       @relation(fields: [clientId], references: [id])
  lead       Lead?         @relation(fields: [leadId], references: [id])
  pipelineStage PipelineStage @relation(fields: [stageId], references: [id])
  activities Activity[]

  @@index([companyId])
  @@map("deals")
}

model Activity {
  id         String        @id @default(uuid())
  companyId  String
  userId     String
  clientId   String?
  dealId     String?
  type       ActivityType
  subject    String
  description String?
  dueAt      DateTime?
  doneAt     DateTime?
  isDone     Boolean       @default(false)
  createdAt  DateTime      @default(now())

  user       User          @relation(fields: [userId], references: [id])
  client     Client?       @relation(fields: [clientId], references: [id])
  deal       Deal?         @relation(fields: [dealId], references: [id])

  @@index([companyId])
  @@map("activities")
}

// ============================================================
// PRODUCTS & TAXES
// ============================================================

model Product {
  id          String      @id @default(uuid())
  companyId   String
  name        String
  description String?
  sku         String?
  barcode     String?
  type        ProductType @default(SERVICE)
  price       Decimal     @db.Decimal(12, 2)
  cost        Decimal?    @db.Decimal(12, 2)
  taxId       String?
  categoryId  String?
  isActive    Boolean     @default(true)
  trackStock  Boolean     @default(false)
  stock       Decimal     @default(0) @db.Decimal(10, 3)
  minStock    Decimal?    @db.Decimal(10, 3)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tax         Tax?        @relation(fields: [taxId], references: [id])
  category    Category?   @relation(fields: [categoryId], references: [id])
  invoiceItems InvoiceItem[]
  quoteItems  QuoteItem[]
  stockMovements StockMovement[]
  deliveryNoteItems DeliveryNoteItem[]
  orderItems  OrderItem[]
  purchaseOrderItems PurchaseOrderItem[]

  @@index([companyId])
  @@map("products")
}

model Category {
  id        String    @id @default(uuid())
  companyId String
  name      String
  products  Product[]

  @@unique([companyId, name])
  @@map("categories")
}

model Tax {
  id        String    @id @default(uuid())
  companyId String
  name      String
  rate      Decimal   @db.Decimal(5, 2)
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]
  invoiceTaxes InvoiceTax[]

  @@index([companyId])
  @@map("taxes")
}

// ============================================================
// INVOICING
// ============================================================

model InvoiceSeries {
  id        String    @id @default(uuid())
  companyId String
  name      String
  prefix    String
  nextNumber Int      @default(1)
  isDefault Boolean   @default(false)

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@unique([companyId, prefix])
  @@map("invoice_series")
}

model Invoice {
  id           String        @id @default(uuid())
  companyId    String
  clientId     String
  projectId    String?
  seriesId     String?
  number       String
  status       InvoiceStatus @default(DRAFT)
  issueDate    DateTime      @default(now())
  dueDate      DateTime?
  currency     String        @default("EUR")
  exchangeRate Decimal?      @db.Decimal(10, 6)
  language     String        @default("es")
  subtotal     Decimal       @db.Decimal(12, 2)
  taxAmount    Decimal       @db.Decimal(12, 2)
  total        Decimal       @db.Decimal(12, 2)
  paidAmount   Decimal       @default(0) @db.Decimal(12, 2)
  notes        String?
  terms        String?
  pdfUrl       String?
  qrCode       String?
  isRecurring  Boolean       @default(false)
  recurringCron String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client       Client        @relation(fields: [clientId], references: [id])
  project      Project?      @relation(fields: [projectId], references: [id])
  series       InvoiceSeries? @relation(fields: [seriesId], references: [id])
  items        InvoiceItem[]
  taxes        InvoiceTax[]
  payments     Payment[]
  verifactu    VerifactuRecord?

  @@unique([companyId, number])
  @@index([companyId, status])
  @@map("invoices")
}

model InvoiceItem {
  id          String    @id @default(uuid())
  invoiceId   String
  productId   String?
  description String
  quantity    Decimal   @db.Decimal(10, 3)
  unitPrice   Decimal   @db.Decimal(12, 2)
  discount    Decimal   @default(0) @db.Decimal(5, 2)
  subtotal    Decimal   @db.Decimal(12, 2)
  order       Int       @default(0)

  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model InvoiceTax {
  id        String    @id @default(uuid())
  invoiceId String
  taxId     String
  rate      Decimal   @db.Decimal(5, 2)
  base      Decimal   @db.Decimal(12, 2)
  amount    Decimal   @db.Decimal(12, 2)

  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tax       Tax       @relation(fields: [taxId], references: [id])

  @@map("invoice_taxes")
}

model Quote {
  id         String      @id @default(uuid())
  companyId  String
  clientId   String
  number     String
  status     QuoteStatus @default(DRAFT)
  issueDate  DateTime    @default(now())
  validUntil DateTime?
  currency   String      @default("EUR")
  exchangeRate Decimal?  @db.Decimal(10, 6)
  language   String      @default("es")
  subtotal   Decimal     @db.Decimal(12, 2)
  taxAmount  Decimal     @db.Decimal(12, 2)
  total      Decimal     @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client     Client      @relation(fields: [clientId], references: [id])
  items      QuoteItem[]
  deliveryNotes DeliveryNote[]

  @@unique([companyId, number])
  @@index([companyId, status])
  @@map("quotes")
}

model QuoteItem {
  id          String    @id @default(uuid())
  quoteId     String
  productId   String?
  description String
  quantity    Decimal   @db.Decimal(10, 3)
  unitPrice   Decimal   @db.Decimal(12, 2)
  discount    Decimal   @default(0) @db.Decimal(5, 2)
  subtotal    Decimal   @db.Decimal(12, 2)
  order       Int       @default(0)

  quote       Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product?  @relation(fields: [productId], references: [id])

  @@map("quote_items")
}

model Payment {
  id          String        @id @default(uuid())
  invoiceId   String
  amount      Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(BANK_TRANSFER)
  paidAt      DateTime      @default(now())
  reference   String?
  notes       String?

  invoice     Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("payments")
}

// ============================================================
// VERIFACTU
// ============================================================

model VerifactuRecord {
  id           String          @id @default(uuid())
  companyId    String
  invoiceId    String          @unique
  xml          String          @db.Text
  hash         String
  previousHash String?
  signature    String?
  status       VerifactuStatus @default(GENERATED)
  aeatResponse String?
  qrCode       String?
  sentAt       DateTime?
  acceptedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice      Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  events       VerifactuEvent[]

  @@index([companyId])
  @@map("verifactu_records")
}

model VerifactuEvent {
  id         String    @id @default(uuid())
  recordId   String
  status     VerifactuStatus
  message    String?
  createdAt  DateTime  @default(now())

  record     VerifactuRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)

  @@map("verifactu_events")
}

// ============================================================
// ALBARANES
// ============================================================

model DeliveryNote {
  id                   String             @id @default(uuid())
  companyId            String
  clientId             String
  quoteId              String?
  number               String
  status               DeliveryNoteStatus @default(DRAFT)
  issueDate            DateTime           @default(now())
  deliveryDate         DateTime?
  notes                String?
  attachments          Json?
  subtotal             Decimal            @db.Decimal(12, 2)
  taxAmount            Decimal            @db.Decimal(12, 2)
  total                Decimal            @db.Decimal(12, 2)
  convertedToInvoiceId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client               Client             @relation(fields: [clientId], references: [id])
  quote                Quote?             @relation(fields: [quoteId], references: [id])
  items                DeliveryNoteItem[]

  @@unique([companyId, number])
  @@index([companyId, status])
  @@map("delivery_notes")
}

model DeliveryNoteItem {
  id             String       @id @default(uuid())
  deliveryNoteId String
  productId      String?
  description    String
  quantity       Decimal      @db.Decimal(10, 3)
  unitPrice      Decimal      @db.Decimal(12, 2)
  discount       Decimal      @default(0) @db.Decimal(5, 2)
  subtotal       Decimal      @db.Decimal(12, 2)
  order          Int          @default(0)

  deliveryNote   DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)
  product        Product?     @relation(fields: [productId], references: [id])

  @@map("delivery_note_items")
}

// ============================================================
// ACCOUNTING
// ============================================================

model Account {
  id          String    @id @default(uuid())
  companyId   String
  code        String
  name        String
  type        String
  parentId    String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent      Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[] @relation("AccountHierarchy")
  journalItems JournalItem[]

  @@unique([companyId, code])
  @@index([companyId])
  @@map("accounts")
}

model JournalEntry {
  id          String           @id @default(uuid())
  companyId   String
  type        JournalEntryType
  reference   String?
  description String
  entryDate   DateTime
  isLocked    Boolean          @default(false)
  createdAt   DateTime         @default(now())

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       JournalItem[]

  @@index([companyId])
  @@index([companyId, entryDate])
  @@map("journal_entries")
}

model JournalItem {
  id           String       @id @default(uuid())
  entryId      String
  accountId    String
  description  String?
  debit        Decimal      @default(0) @db.Decimal(12, 2)
  credit       Decimal      @default(0) @db.Decimal(12, 2)

  entry        JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account      Account      @relation(fields: [accountId], references: [id])

  @@index([entryId])
  @@map("journal_items")
}

model BankAccount {
  id         String    @id @default(uuid())
  companyId  String
  name       String
  iban       String?
  bic        String?
  currency   String    @default("EUR")
  balance    Decimal   @default(0) @db.Decimal(12, 2)
  isActive   Boolean   @default(true)

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@index([companyId])
  @@map("bank_accounts")
}

model BankTransaction {
  id              String    @id @default(uuid())
  bankAccountId   String
  description     String
  amount          Decimal   @db.Decimal(12, 2)
  date            DateTime
  isReconciled    Boolean   @default(false)
  reconcileStatus String?
  reference       String?

  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@map("bank_transactions")
}

// ============================================================
// INVENTORY
// ============================================================

model Warehouse {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  description String?
  address     String?
  phone       String?
  email       String?
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  movements StockMovement[]

  @@index([companyId])
  @@map("warehouses")
}

model StockMovement {
  id          String            @id @default(uuid())
  warehouseId String
  productId   String
  type        StockMovementType
  quantity    Decimal           @db.Decimal(10, 3)
  reference   String?
  notes       String?
  createdAt   DateTime          @default(now())

  warehouse   Warehouse         @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  product     Product           @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([warehouseId, createdAt])
  @@map("stock_movements")
}

model Supplier {
  id          String    @id @default(uuid())
  companyId   String
  name        String
  email       String?
  phone       String?
  cifNif      String?
  contactName String?
  address     String?
  city        String?
  country     String    @default("ES")
  website     String?
  notes       String?
  bankAccount String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]

  @@index([companyId])
  @@map("suppliers")
}

// ============================================================
// NOTIFICATIONS & AUDIT
// ============================================================

model Notification {
  id        String              @id @default(uuid())
  companyId String
  userId    String?
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  isRead    Boolean             @default(false)
  data      Json?
  createdAt DateTime            @default(now())

  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, isRead])
  @@map("notifications")
}

model AuditLog {
  id         String    @id @default(uuid())
  companyId  String
  userId     String?
  action     String
  entity     String
  entityId   String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())

  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id])

  @@index([companyId, entity])
  @@map("audit_logs")
}

// ============================================================
// RRHH
// ============================================================

model Employee {
  id                   String         @id @default(uuid())
  companyId            String
  firstName            String
  lastName             String
  email                String?
  phone                String?
  nif                  String?
  socialSecurityNumber String?
  position             String?
  department           String?
  contractType         ContractType   @default(INDEFINIDO)
  startDate            DateTime
  endDate              DateTime?
  salary               Decimal        @db.Decimal(12, 2)
  bankAccount          String?
  bankHolder           String?
  address              String?
  city                 String?
  province             String?
  postalCode           String?
  workingHours         Decimal        @default(40) @db.Decimal(4, 1)
  schedule             Json?
  clockToken           String?        @unique
  portalPassword       String?
  portalActivatedAt    DateTime?
  status               EmployeeStatus @default(ACTIVE)
  avatar               String?
  notes                String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  company              Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  timeEntries          TimeEntry[]
  leaveRequests        LeaveRequest[]
  payrolls             Payroll[]

  @@index([companyId, status])
  @@map("employees")
}

model TimeEntry {
  id           String    @id @default(uuid())
  companyId    String
  employeeId   String
  projectId    String?
  date         DateTime
  clockIn      DateTime
  clockOut     DateTime?
  breakMinutes Int       @default(0)
  totalMinutes Int?
  latitude     Float?
  longitude    Float?
  locationOut  Json?
  method       String?
  notes        String?
  createdAt    DateTime  @default(now())

  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  project      Project?  @relation(fields: [projectId], references: [id])

  @@index([companyId, employeeId])
  @@index([employeeId, date])
  @@index([projectId])
  @@map("time_entries")
}

model LeaveRequest {
  id          String      @id @default(uuid())
  companyId   String
  employeeId  String
  type        LeaveType   @default(VACATION)
  startDate   DateTime
  endDate     DateTime
  days        Int
  status      LeaveStatus @default(PENDING)
  reason      String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employee    Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId, employeeId])
  @@index([companyId, status])
  @@map("leave_requests")
}

// ============================================================
// NÓMINAS
// ============================================================

model Payroll {
  id              String        @id @default(uuid())
  companyId       String
  employeeId      String
  year            Int
  month           Int

  baseSalary      Decimal       @db.Decimal(12, 2)
  overtimePay     Decimal       @default(0) @db.Decimal(12, 2)
  bonuses         Decimal       @default(0) @db.Decimal(12, 2)
  grossSalary     Decimal       @db.Decimal(12, 2)

  ssEmployeeRate  Decimal       @db.Decimal(6, 4)
  ssEmployerRate  Decimal       @db.Decimal(6, 4)
  ssEmployee      Decimal       @db.Decimal(12, 2)
  ssEmployer      Decimal       @db.Decimal(12, 2)

  irpfRate        Decimal       @db.Decimal(5, 2)
  irpfAmount      Decimal       @db.Decimal(12, 2)

  otherDeductions Decimal       @default(0) @db.Decimal(12, 2)
  netSalary       Decimal       @db.Decimal(12, 2)
  totalCost       Decimal       @db.Decimal(12, 2)

  status          PayrollStatus @default(DRAFT)
  paymentDate     DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([companyId, employeeId, year, month])
  @@index([companyId, year, month])
  @@map("payrolls")
}

// ============================================================
// AUTOMATIONS
// ============================================================

model Automation {
  id           String               @id @default(uuid())
  companyId    String
  name         String
  description  String?
  trigger      AutomationTrigger
  conditions   Json?
  action       AutomationActionType
  actionConfig Json
  isActive     Boolean              @default(true)
  runCount     Int                  @default(0)
  lastRunAt    DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  company      Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  logs         AutomationLog[]

  @@index([companyId, isActive])
  @@map("automations")
}

model AutomationLog {
  id           String    @id @default(uuid())
  automationId String
  companyId    String
  trigger      String
  success      Boolean
  errorMessage String?
  payload      Json?
  createdAt    DateTime  @default(now())

  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId, createdAt])
  @@index([companyId, createdAt])
  @@map("automation_logs")
}

// ============================================================
// PROJECTS
// ============================================================

model Project {
  id          String        @id @default(uuid())
  companyId   String
  clientId    String?
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  budget      Decimal?      @db.Decimal(12, 2)
  hourlyRate  Decimal?      @db.Decimal(8, 2)
  startDate   DateTime?
  endDate     DateTime?
  color       String        @default("#6366f1")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client      Client?       @relation(fields: [clientId], references: [id])
  timeEntries TimeEntry[]
  invoices    Invoice[]

  @@index([companyId])
  @@index([companyId, status])
  @@map("projects")
}

// ============================================================
// CUSTOM FIELDS
// ============================================================

model CustomField {
  id        String    @id @default(uuid())
  companyId String
  entity    String
  name      String
  type      String
  options   Json?
  required  Boolean   @default(false)
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  values    CustomFieldValue[]

  @@index([companyId, entity])
  @@map("custom_fields")
}

model CustomFieldValue {
  id            String      @id @default(uuid())
  customFieldId String
  entityId      String
  value         String?

  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, entityId])
  @@index([entityId])
  @@map("custom_field_values")
}

// ============================================================
// PEDIDOS (Fase 8b)
// ============================================================

model Order {
  id               String      @id @default(uuid())
  companyId        String
  clientId         String
  number           String
  status           OrderStatus @default(PENDING)
  issueDate        DateTime    @default(now())
  deliveryDate     DateTime?
  notes            String?
  subtotal         Decimal     @default(0) @db.Decimal(12, 2)
  taxAmount        Decimal     @default(0) @db.Decimal(12, 2)
  total            Decimal     @default(0) @db.Decimal(12, 2)
  currency         String      @default("EUR")
  convertedToDeliveryNoteId String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  company          Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client           Client      @relation(fields: [clientId], references: [id])
  items            OrderItem[]

  @@unique([companyId, number])
  @@index([companyId, status])
  @@index([companyId, clientId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(uuid())
  orderId     String
  productId   String?
  description String
  quantity    Decimal  @db.Decimal(12, 3)
  unitPrice   Decimal  @db.Decimal(12, 2)
  discount    Decimal  @default(0) @db.Decimal(5, 2)
  taxRate     Decimal  @default(0) @db.Decimal(5, 2)
  subtotal    Decimal  @db.Decimal(12, 2)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model PurchaseOrder {
  id          String              @id @default(uuid())
  companyId   String
  supplierId  String
  number      String
  status      PurchaseOrderStatus @default(DRAFT)
  issueDate   DateTime            @default(now())
  expectedDate DateTime?
  notes       String?
  subtotal    Decimal             @default(0) @db.Decimal(12, 2)
  taxAmount   Decimal             @default(0) @db.Decimal(12, 2)
  total       Decimal             @default(0) @db.Decimal(12, 2)
  currency    String              @default("EUR")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company     Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]

  @@unique([companyId, number])
  @@index([companyId, status])
  @@index([companyId, supplierId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String?
  description     String
  quantity        Decimal       @db.Decimal(12, 3)
  receivedQty     Decimal       @default(0) @db.Decimal(12, 3)
  unitPrice       Decimal       @db.Decimal(12, 2)
  taxRate         Decimal       @default(0) @db.Decimal(5, 2)
  subtotal        Decimal       @db.Decimal(12, 2)

  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product?      @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

// ============================================================
// FISCAL
// ============================================================

model Expense {
  id          String   @id @default(uuid())
  companyId   String
  date        DateTime
  description String
  supplier    String?
  invoiceRef  String?
  subtotal    Decimal  @db.Decimal(12, 2)
  vatRate     Decimal  @default(21) @db.Decimal(5, 2)
  vatAmount   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
  category    String   @default("OTROS")
  isDeductible Boolean @default(true)
  createdAt   DateTime @default(now())

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@map("expenses")
}

model FiscalPeriod {
  id          String   @id @default(uuid())
  companyId   String
  year        Int
  quarter     Int
  model303Filed Boolean @default(false)
  model130Filed Boolean @default(false)
  model111Filed Boolean @default(false)
  model303Amount Decimal? @db.Decimal(12, 2)
  model130Amount Decimal? @db.Decimal(12, 2)
  model111Amount Decimal? @db.Decimal(12, 2)
  filedAt     DateTime?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year, quarter])
  @@map("fiscal_periods")
}
