{
  "name": "saas-erp",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:packages": "cd packages/types && tsc -p tsconfig.build.json && cd ../database && tsc -p tsconfig.build.json",
    "dev": "turbo dev",
    "start:api": "cd apps/api && nest build && node dist/apps/api/src/main.js",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:studio": "cd packages/database && pnpm db:studio",
    "db:seed": "cd packages/database && pnpm db:seed",
    "db:migrate": "turbo db:migrate"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@swc/core",
      "msgpackr-extract",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
