# Database (Supabase connection pooler)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# JWT - generate with: openssl rand -base64 64
JWT_SECRET="change-me-min-32-chars-random-string"
JWT_REFRESH_SECRET="change-me-min-32-chars-random-string-2"

# App
PORT=3001
CLIENT_URL="https://tu-app.vercel.app"
NODE_ENV="production"

# Google OAuth (optional - leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email - Resend (https://resend.com - free 3000 emails/month)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="ERP SaaS <noreply@tudominio.com>"

# Stripe (https://stripe.com - optional)
STRIPE_SECRET_KEY="sk_live_xxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxx"
STRIPE_PRICE_STARTER="price_xxxxxxxxxxxx"
STRIPE_PRICE_PRO="price_xxxxxxxxxxxx"
STRIPE_PRICE_ENTERPRISE="price_xxxxxxxxxxxx"

# Redis (optional - for queues/cache)
REDIS_URL="redis://localhost:6379"
